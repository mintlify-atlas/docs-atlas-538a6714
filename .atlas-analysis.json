  "keyFeatures": [
    "Interactive tourism onboarding system with OAuth authentication",
    "Gamification with badges and personalized route recommendations",
    "Multi-language support (Spanish, English, Náhuatl)",
    "Government portal with institutional information and services",
    "User profiles with preferences, routes, and visit tracking",
    "Dynamic ticket generation with QR codes and social sharing",
    "Supabase-powered backend with PostgreSQL database",
    "Server-side rendering with Astro and React components"
  ],
  "publicApiSurface": [
    "POST /api/turismo/ticket - Generate tourism tickets",
    "POST /api/turismo/verify-visit - Verify visit codes",
    "POST /api/turismo/rate-visit - Rate tourism experiences",
    "GET /api/turismo/og/[code] - Generate Open Graph images",
    "POST /api/chat - AI chat endpoint",
    "supabase.auth.signInWithOAuth() - OAuth authentication",
    "supabase.from('user_preferences').upsert() - Save user preferences",
    "supabase.from('user_routes').select() - Get user routes",
    "supabase.from('user_badges').insert() - Unlock badges",
    "getUserProfile(userId) - Fetch user profile",
    "saveUserRoute(route) - Save tourism route",
    "calculateRecommendations(preferences) - Generate personalized recommendations",
    "unlockBadges(preferences) - Calculate earned badges"
  ]
